<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".HomePageWork.HomePageMain">

    <com.google.android.material.appbar.AppBarLayout
        app:liftOnScroll="true"

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
       >

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/actionBarSize"
            android:background="@color/actionBar"

            android:elevation="52dp"
            android:paddingStart="22dp"
            android:paddingEnd="16dp"
            app:menu="@menu/top_app_bar"
            app:title="Hi,UserName"
            app:titleTextAppearance="@style/textFontStyle" />

    </com.google.android.material.appbar.AppBarLayout>


    <TextView
        android:id="@+id/textView2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/arrow2"
        android:gravity="center"
        android:padding="3dp"
        android:text="YOU ARE SAFE"
        android:textColor="@color/Textwhite"
        android:textSize="16sp"
        android:textStyle="bold"
        tools:ignore="TextContrastCheck" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="12dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="9dp"
        android:layout_marginBottom="9dp"
       >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:paddingTop="8dp"
            android:paddingStart="16dp"
            android:paddingBottom="5dp"
            android:layout_height="wrap_content"
            android:text="Real time tracking"
            android:textStyle="bold"
            android:textSize="16sp"

            />


            <ImageView
                android:id="@+id/imageView3"
                android:layout_width="match_parent"
                android:layout_height="139dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"

                app:srcCompat="@drawable/mapdummy" />

            <ImageButton
                android:id="@+id/shareLiveLoc"
                android:layout_width="334dp"
                android:layout_height="45dp"
                android:layout_gravity="center"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="12dp"
                android:contentDescription="@string/todo"
                android:paddingStart="1dp"
                android:paddingEnd="1dp"
                android:scaleType="centerCrop"
                android:src="@drawable/share_live_location_button"
                tools:ignore="TouchTargetSizeCheck" />


        </LinearLayout>
    </androidx.cardview.widget.CardView>


    <androidx.cardview.widget.CardView
        android:id="@+id/EmergencyContacts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:cardCornerRadius="8dp"
        app:cardElevation="12dp"

        android:clickable="true"
        android:focusable="true"

        android:elevation="12dp"

        android:background="@color/white"
        android:gravity="center"
        android:padding="16dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        >


        <TextView
            android:id="@+id/textView3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"

            android:textColor="@color/black"
            android:padding="18dp"
            android:textStyle="bold"
            android:textSize="18sp"
            android:text="Emergency Contacts" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="225dp"
        android:orientation="horizontal">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_margin="12dp"

            android:layout_weight="1"
            app:cardCornerRadius="8dp"
            app:cardElevation="12dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="167dp"
                android:paddingTop="12dp"
                android:src="@drawable/homepage_img1" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="Safety Measures \nDuring Emergencies"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView

            android:layout_width="0dp"
            android:layout_height="match_parent"

            android:layout_margin="12dp"
            android:layout_weight="1"
            app:cardCornerRadius="8dp"
            app:cardElevation="12dp">

            <ImageView
                android:layout_width="174dp"
                android:layout_height="198dp"
                android:src="@drawable/homepage_img2" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:text="Fake Call"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>


    </LinearLayout>




    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="12dp">

        <com.google.android.material.bottomappbar.BottomAppBar
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/bottomAppBar"
            app:elevation="12dp"
            android:layout_gravity="bottom"
            android:backgroundTint="@color/actionBar"
            app:fabCradleMargin="10dp"
            app:fabAlignmentMode="center"
            app:fabCradleRoundedCornerRadius="30dp">

            <com.google.android.material.bottomnavigation.BottomNavigationView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="0dp"  android:id="@+id/bottomNavView"
                app:labelVisibilityMode="labeled"
                app:itemIconTint="@drawable/bottom_nav_selected_back"
                app:itemTextColor="@drawable/bottom_nav_selected_back"

                app:menu="@menu/bottom_app_bar"
                android:background="@android:color/transparent"/>

        </com.google.android.material.bottomappbar.BottomAppBar>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fabCustomSize="65dp"
            android:backgroundTint="@color/sos_page"
            app:tint="@android:color/white"
            app:maxImageSize="35dp"
            android:contentDescription="@string/todo"
            android:src="@drawable/bottombar_sos_icon"
            app:layout_anchor="@id/bottomAppBar"
            app:layout_anchorGravity="center" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>







    </LinearLayout>