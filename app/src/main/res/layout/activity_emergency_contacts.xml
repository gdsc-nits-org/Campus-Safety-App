<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:padding="8dp">

    <!-- Back Button -->
    <TextView
        android:id="@+id/goBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:drawablePadding="8dp"
        android:focusable="true"
        android:padding="8dp"
        android:text="Back"
        android:drawableRight="@drawable/arrow"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Emergency Contacts Header -->
    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/goBack">

        <TextView
            android:id="@+id/myContactsText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:text="Emergency Contacts"
            android:textColor="@color/red"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnAddContact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:contentDescription="Add Contact"
            android:src="@drawable/ic_add" />
    </LinearLayout>

    <!-- Search View -->
    <androidx.appcompat.widget.SearchView
        android:id="@+id/searchEmergencyContacts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/search_background"
        android:iconifiedByDefault="false"
        android:queryHint="Search Contacts..."
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout"
        app:queryHint="Search Contacts..."

        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:iconifiedByDefault="false"/>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEmergencyContacts"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginEnd="32dp"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toBottomOf="@id/searchEmergencyContacts"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/scroll_bar_container" />

    <!-- Scrollbar Container -->
    <FrameLayout
        android:id="@+id/scroll_bar_container"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toTopOf="@id/rvEmergencyContacts"
        app:layout_constraintBottom_toBottomOf="@id/rvEmergencyContacts"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Scrollbar -->
        <View
            android:id="@+id/scroll_bar"
            android:layout_width="4dp"
            android:layout_height="40dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/scroll_bar_bg" />
    </FrameLayout>

    <!-- Alphabet Scroller -->

    <LinearLayout
        android:id="@+id/alphabet_scroller"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginEnd="4dp"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="@id/rvEmergencyContacts"
        app:layout_constraintBottom_toBottomOf="@id/rvEmergencyContacts"
        app:layout_constraintEnd_toEndOf="parent">
        <!-- Letters (A-Z) will be dynamically added -->
    </LinearLayout>

    <!-- Visible Letter -->
    <TextView
        android:id="@+id/visible_letter"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:visibility="gone"
        android:gravity="center"
        android:textSize="48sp"
        android:textColor="@android:color/white"
        android:background="@drawable/scroll_letter_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
