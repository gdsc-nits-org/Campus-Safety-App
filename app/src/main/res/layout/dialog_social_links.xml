<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="20dp"
    android:gravity="center_horizontal"
    android:elevation="8dp">

    <!-- Dialog Title -->
    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Connect"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_marginBottom="15dp"/>

    <!-- Horizontal Layout for Social Media Icons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="15dp">

        <ImageView
            android:id="@+id/btnGitHub"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/github"
            android:scaleType="fitCenter"
            android:padding="10dp"
            android:contentDescription="GitHub"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/btnLinkedIn"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/linkedin"
            android:scaleType="fitCenter"
            android:padding="10dp"
            android:contentDescription="LinkedIn"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/btnInstagram"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/instagram"
            android:scaleType="fitCenter"
            android:padding="10dp"
            android:contentDescription="Instagram"
            android:clickable="true"
            android:focusable="true"/>

        <ImageView
            android:id="@+id/btnFacebook"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/facebook"
            android:scaleType="fitCenter"
            android:padding="10dp"
            android:contentDescription="Facebook"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Separator Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/darker_gray"/>

    <!-- Support Developers Text -->
    <TextView
        android:id="@+id/supportDevelopersText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Support the developers"
        android:textSize="16sp"
        android:textColor="@android:color/black"
        android:layout_marginTop="10dp"/>

</LinearLayout>
